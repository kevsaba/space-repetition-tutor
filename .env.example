# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spaced_repetition_tutor?schema=public"

# LLM Configuration
# Base URL for the LLM API (will have /chat/completions appended automatically)
# For OpenAI: https://api.openai.com/v1
# For LiteLLM proxy: https://your-proxy-url/v1
LLM_URL=https://aikeys.maibornwolff.de/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gpt-4o-mini
# Optional: Request timeout in milliseconds (default: 30000)
LLM_TIMEOUT=30000

# JWT Secret (generate a random string for production)
JWT_SECRET=your-jwt-secret-key-change-in-production

# Supabase (for future auth upgrade)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
