# Space Repetition Tutor - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# For local development, you can use:
# 1. Local PostgreSQL (see docker-compose.yml)
# 2. Supabase (https://supabase.com) - Free PostgreSQL hosting
# 3. Any PostgreSQL-compatible database

# Connection string for the application (with pooling if using Supabase)
# Format: postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-1-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/spaced_repetition_tutor?schema=public"

# Direct connection string for database migrations (no pooling)
# Format: postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-1-region.pooler.supabase.com:5432/postgres
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/spaced_repetition_tutor"

# ============================================================================
# LLM CONFIGURATION
# ============================================================================
# The app uses OpenAI-compatible APIs. You can use:
# - OpenAI (https://platform.openai.com/api-keys)
# - LiteLLM proxy (https://docs.litellm.ai/)
# - Azure OpenAI
# - Any OpenAI-compatible provider

# Base URL for the LLM API
# Examples:
# - OpenAI: https://api.openai.com/v1
# - LiteLLM: https://your-litellm-proxy.com/v1
# - Azure: https://your-resource.openai.azure.com/openai/deployments/your-deployment
LLM_API_URL=https://api.openai.com/v1

# Your API key for the LLM provider
# Get one from: https://platform.openai.com/api-keys
LLM_API_KEY=sk-your-api-key-here

# Model to use for question generation and evaluation
# Options: gpt-4o-mini, gpt-4o, gpt-3.5-turbo, or any compatible model
LLM_MODEL=gpt-4o-mini

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Environment: development, production, or test
NODE_ENV=development

# Port for the Next.js dev server (default: 3000)
PORT=3000

# ============================================================================
# AUTHENTICATION
# ============================================================================

# Secret key for JWT token signing
# Generate a secure random string for production!
# Use: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-change-in-production

# ============================================================================
# OPTIONAL: Supabase Auth (not currently used)
# ============================================================================
# These are optional if you want to use Supabase Authentication instead of
# the built-in username/password auth. This requires additional setup.

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
