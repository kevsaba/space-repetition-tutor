// Prisma Schema for Space Repetition Tutor
// Version: 1.3
// Database: PostgreSQL (Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// CORE ENTITIES
// ============================================================

/// User accounts - simple auth for v1, upgradeable to Supabase Auth later
model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String   // hashed with bcrypt
  createdAt DateTime @default(now())

  // Relations
  sessions      Session[]
  userQuestions UserQuestion[]
  questions     Question[]  // Questions created by this user (as templates)
  careers       UserCareer[]

  @@index([username])
  @@map("users")
}

/// Topics represent areas of study (e.g., "Java Concurrency", "REST API Design")
model Topic {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // e.g., "Backend", "Database", "Distributed Systems"
  track       Track    @default(JAVA)
  difficulty  Difficulty @default(MID)
  isTemplate  Boolean  @default(false) // Template topics can be reused

  createdAt DateTime @default(now())

  // Relations
  questions        Question[]
  careerTopics     CareerTopic[]

  @@index([track])
  @@index([category])
  @@map("topics")
}

/// Questions - the core content unit
model Question {
  id          String       @id @default(cuid())
  content     String       @db.Text
  type        QuestionType @default(CONCEPTUAL)
  difficulty  Difficulty   @default(MID)
  topicId     String
  topic       Topic        @relation(fields: [topicId], references: [id], onDelete: Cascade)

  isTemplate Boolean  @default(false) // Template questions can be reused
  createdBy  String?  // userId if template created by user
  creator    User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  // Optional template fields for pre-generated questions
  expectedTopics String[]   // Topics this question covers
  hint           String?    @db.Text

  createdAt DateTime @default(now())

  // Relations
  userQuestions UserQuestion[]

  @@index([topicId])
  @@index([type])
  @@index([isTemplate])
  @@map("questions")
}

/// UserQuestion - tracks user's progress on each question via Leitner system
model UserQuestion {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  // Leitner System Fields
  box         Int      @default(1) // 1, 2, or 3
  dueDate     DateTime
  streak      Int      @default(0) // Consecutive passes
  lastSeenAt  DateTime?

  createdAt DateTime @default(now())

  // Relations
  answers Answer[]

  @@unique([userId, questionId])
  @@index([userId, dueDate]) // Composite index for fetching due questions
  @@index([dueDate])         // For cleanup/archival queries
  @@map("user_questions")
}

/// Answers - records of user responses
model Answer {
  id             String       @id @default(cuid())
  userQuestionId String
  userQuestion   UserQuestion @relation(fields: [userQuestionId], references: [id], onDelete: Cascade)

  content     String   @db.Text
  passed      Boolean
  feedback    Json     // Structured feedback from LLM
  answeredAt  DateTime @default(now())

  // Follow-up tracking
  isFollowUp     Boolean @default(false) // Whether this is a follow-up answer
  followUpQuestion String? // The follow-up question text (if this is a follow-up answer)

  // Session tracking (optional, for analytics)
  sessionId String?

  @@index([userQuestionId])
  @@index([answeredAt])
  @@map("answers")
}

/// Sessions - track study sessions (FREE or INTERVIEW mode)
model Session {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode        SessionMode   @default(FREE)
  status      SessionStatus @default(IN_PROGRESS)

  startedAt   DateTime      @default(now())
  completedAt DateTime?

  // Track context
  careerId    String?       // If interview mode, which career track

  @@index([userId])
  @@index([status])
  @@map("sessions")
}

// ============================================================
// INTERVIEW MODE ENTITIES
// ============================================================

/// Career tracks for interview mode (e.g., "Senior Java Backend", "Full Stack Developer")
model Career {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @db.Text

  createdAt DateTime @default(now())

  // Relations
  careerTopics  CareerTopic[]
  userCareers   UserCareer[]

  @@map("careers")
}

/// Career-Topic relationships (order matters for interview flow)
model CareerTopic {
  id        String   @id @default(cuid())
  careerId  String
  career    Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  topicId   String
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  order     Int // Position in interview sequence

  createdAt DateTime @default(now())

  @@unique([careerId, topicId])
  @@index([careerId])
  @@map("career_topics")
}

/// User-Career assignments (which careers a user is preparing for)
model UserCareer {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  careerId  String
  career    Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)

  isActive  Boolean  @default(true) // User can have multiple careers, one active at a time
  startedAt DateTime @default(now())

  @@unique([userId, careerId])
  @@index([userId])
  @@map("user_careers")
}

// ============================================================
// ENUMS
// ============================================================

enum Track {
  JAVA
  PYTHON
  DISTRIBUTED_SYSTEMS
  GENERAL
}

enum QuestionType {
  CONCEPTUAL  // v1
  CODING      // v2
  DESIGN      // v2
}

enum Difficulty {
  JUNIOR
  MID
  SENIOR
}

enum SessionMode {
  FREE       // User explores topics freely
  INTERVIEW  // Structured interview preparation
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}
