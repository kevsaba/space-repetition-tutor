generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// User accounts - simple auth for v1, upgradeable to Supabase Auth later
model User {
  id            String         @id @default(cuid())
  username      String         @unique
  password      String
  createdAt     DateTime       @default(now())
  questions     Question[]
  sessions      Session[]
  careers       UserCareer[]
  userQuestions UserQuestion[]
  llmConfig     UserLlmConfig?

  @@index([username])
  @@map("users")
}

/// Topics represent areas of study (e.g., "Java Concurrency", "REST API Design")
model Topic {
  id           String        @id @default(cuid())
  name         String        @unique
  category     String
  track        Track         @default(JAVA)
  difficulty   Difficulty    @default(MID)
  isTemplate   Boolean       @default(false)
  createdAt    DateTime      @default(now())
  careerTopics CareerTopic[]
  questions    Question[]

  @@index([track])
  @@index([category])
  @@map("topics")
}

/// Questions - the core content unit
model Question {
  id             String         @id @default(cuid())
  content        String
  type           QuestionType   @default(CONCEPTUAL)
  difficulty     Difficulty     @default(MID)
  topicId        String
  isTemplate     Boolean        @default(false)
  createdBy      String?
  expectedTopics String[]
  hint           String?
  createdAt      DateTime       @default(now())
  creator        User?          @relation(fields: [createdBy], references: [id])
  topic          Topic          @relation(fields: [topicId], references: [id], onDelete: Cascade)
  userQuestions  UserQuestion[]

  @@index([topicId])
  @@index([type])
  @@index([isTemplate])
  @@map("questions")
}

/// UserQuestion - tracks user's progress on each question via Leitner system
model UserQuestion {
  id         String    @id @default(cuid())
  userId     String
  questionId String
  box        Int       @default(1)
  dueDate    DateTime
  streak     Int       @default(0)
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  answers    Answer[]
  question   Question  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, dueDate])
  @@index([dueDate])
  @@index([userId, box])
  @@index([userId, lastSeenAt])
  @@map("user_questions")
}

/// Answers - records of user responses
model Answer {
  id               String       @id @default(cuid())
  userQuestionId   String
  content          String
  passed           Boolean
  feedback         Json
  answeredAt       DateTime     @default(now())
  isFollowUp       Boolean      @default(false)
  followUpQuestion String?
  sessionId        String?
  userQuestion     UserQuestion @relation(fields: [userQuestionId], references: [id], onDelete: Cascade)

  @@index([userQuestionId])
  @@index([answeredAt])
  @@map("answers")
}

/// Sessions - track study sessions (FREE or INTERVIEW mode)
model Session {
  id          String        @id @default(cuid())
  userId      String
  mode        SessionMode   @default(FREE)
  status      SessionStatus @default(IN_PROGRESS)
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  careerId    String?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("sessions")
}

/// Career tracks for interview mode (e.g., "Senior Java Backend", "Full Stack Developer")
model Career {
  id           String        @id @default(cuid())
  name         String        @unique
  description  String
  createdAt    DateTime      @default(now())
  careerTopics CareerTopic[]
  userCareers  UserCareer[]

  @@map("careers")
}

/// Career-Topic relationships (order matters for interview flow)
model CareerTopic {
  id        String   @id @default(cuid())
  careerId  String
  topicId   String
  order     Int
  createdAt DateTime @default(now())
  career    Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@unique([careerId, topicId])
  @@index([careerId])
  @@map("career_topics")
}

/// User-Career assignments (which careers a user is preparing for)
model UserCareer {
  id        String   @id @default(cuid())
  userId    String
  careerId  String
  isActive  Boolean  @default(true)
  startedAt DateTime @default(now())
  career    Career   @relation(fields: [careerId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@index([userId])
  @@map("user_careers")
}

enum Track {
  JAVA
  PYTHON
  DISTRIBUTED_SYSTEMS
  GENERAL
}

enum QuestionType {
  CONCEPTUAL
  CODING
  DESIGN
  UPLOADED
}

enum Difficulty {
  JUNIOR
  MID
  SENIOR
}

enum SessionMode {
  FREE
  INTERVIEW
}

enum SessionStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

/// Per-user LLM configuration with encrypted API key storage
model UserLlmConfig {
  id               String             @id @default(cuid())
  userId           String             @unique
  apiUrl           String             @default("https://api.openai.com/v1")
  apiKeyEncrypted  String?            // NULL = session storage, value = encrypted key
  model            String             @default("gpt-4o-mini")
  storagePreference StoragePreference @default(SESSION)
  strictnessLevel  StrictnessLevel    @default(DEFAULT)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_llm_configs")
}

enum StoragePreference {
  SESSION
  DATABASE
}

enum StrictnessLevel {
  DEFAULT
  STRICT
  LENIENT
}
